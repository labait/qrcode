rules_version = '2';

// Copia tutto questo file in Firebase Console → Firestore → Regole → Pubblica
// (oppure: firebase deploy --only firestore:rules)

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentAccountPath() {
      return /databases/$(database)/documents/accounts/$(request.auth.uid);
    }

    /** Allineato a `isAdmin()` sul client: `roles` deve contenere la stringa "admin". */
    function isAdmin() {
      return signedIn() &&
        exists(currentAccountPath()) &&
        get(currentAccountPath()).data.keys().hasAny(['roles']) &&
        get(currentAccountPath()).data.roles is list &&
        get(currentAccountPath()).data.roles.hasAny(['admin']);
    }

    function ownsAccountDoc() {
      return signedIn() &&
        resource != null &&
        resource.data.keys().hasAny(['uid']) &&
        resource.data.uid == request.auth.uid;
    }

    function uidUnchanged() {
      return request.resource.data.keys().hasAny(['uid']) &&
        resource.data.keys().hasAny(['uid']) &&
        request.resource.data.uid == resource.data.uid;
    }

    /** Il proprietario non può modificare il campo roles. */
    function accountRolesUntouched() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['roles']);
    }

    /**
     * Il proprietario può modificare solo firstname e lastname (oltre al vincolo su roles).
     * uid, roles, email, name e gli altri campi restano invariati lato proprietario non admin.
     */
    function ownerAccountOnlyProfileNames() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['firstname', 'lastname']);
    }

    match /accounts/{accountId} {
      // Proprietario: legge solo il proprio documento ({uid}). Admin: qualsiasi account.
      allow read: if signedIn() &&
        (request.auth.uid == accountId || isAdmin());

      allow create: if isAdmin() || (
          signedIn() &&
          accountId == request.auth.uid &&
          request.resource.data.keys().hasAll([
            'uid',
            'roles',
            'name',
            'email',
            'firstname',
            'lastname'
          ]) &&
          request.resource.data.uid == request.auth.uid &&
          request.resource.data.roles is list &&
          !request.resource.data.roles.hasAny(['admin']) &&
          request.resource.data.name is string &&
          request.resource.data.email is string &&
          request.resource.data.firstname is string &&
          request.resource.data.lastname is string &&
          request.auth.token.email == request.resource.data.email
        );

      allow update: if isAdmin() ||
        (
          ownsAccountDoc() &&
          uidUnchanged() &&
          accountRolesUntouched() &&
          ownerAccountOnlyProfileNames()
        );

      /** Solo gli amministratori possono cancellare account. */
      allow delete: if isAdmin();
    }

    /** Tutti leggono gli item (anche non autenticati); modifiche solo admin. */
    match /items/{itemId} {
      allow read: if true;

      allow create, update, delete: if isAdmin();
    }

    /** Stesso schema degli item. */
    match /events/{eventId} {
      allow read: if true;

      allow create, update, delete: if isAdmin();
    }

    /** Regole conservative (come items): pubblico può leggere; scrittura solo admin. */
    match /qrcodes/{qrcodeId} {
      allow read: if true;

      allow create, update, delete: if isAdmin();
    }
  }
}
